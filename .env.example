# Google Workspace sign-in. OAuth client IDs are public browser identifiers.
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_WORKSPACE_DOMAIN=aiifyit.com

# Future authenticated automation endpoint. It must verify the Google ID token.
VITE_SOW_SUBMIT_URL=

# Local interface development only; never enable in a production environment.
VITE_SOW_DEV_AUTH=false
